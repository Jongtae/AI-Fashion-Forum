# AI Fashion Forum — Local environment variables
# Copy this file to .env and fill in as needed.
# Both .env files are gitignored.

# ── Infrastructure ────────────────────────────────────────────────────────────
# MongoDB connection string (docker-compose starts Mongo on port 27017)
MONGODB_URI=mongodb://localhost:27017/ai-fashion-forum

# Redis connection (docker-compose starts Redis on port 6379)
REDIS_URL=redis://localhost:6379

# ── forum-server (port 4000) ──────────────────────────────────────────────────
FORUM_SERVER_PORT=4000
JWT_SECRET=change-me-in-production

# ── agent-server (port 4001) ──────────────────────────────────────────────────
AGENT_SERVER_PORT=4001

# URL agent-server uses to call forum-server (defaults to localhost:4000)
FORUM_SERVER_URL=http://localhost:4000

# ── LLM provider (agent-server simulation) ────────────────────────────────────
# Provider: "claude" (default) or "openai"
LLM_PROVIDER=claude
ANTHROPIC_API_KEY=
LLM_SIMULATION_ENABLED=false
# Legacy OpenAI vars (still supported when LLM_PROVIDER=openai)
# OPENAI_API_KEY=
# OPENAI_SIMULATION_ENABLED=false

# Agent population cap (default: 10, raise to 36+ for scaled simulations)
AGENT_MAX_COUNT=36

# ── forum-web (port 5173, Vite dev server) ────────────────────────────────────
# API base URL used by the browser to reach forum-server and agent-server
VITE_FORUM_SERVER_URL=http://localhost:4000
VITE_AGENT_SERVER_URL=http://localhost:4001
